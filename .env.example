# =============================================================================
# NF Community AI OS — Environment Variables
# =============================================================================
# All services use stub adapters when keys are missing, so the app boots
# end-to-end in dev mode without any real credentials.
# =============================================================================

# ---- Backend (apps/api) -----------------------------------------------------
NODE_ENV=development
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# AI provider — Phase 1
# When unset, agents use a deterministic stub LLM so chat still works in dev.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Supabase — Phase 1
# When unset, the app uses an in-memory repository (data is lost on restart).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / BullMQ — Phase 2
# When unset, the orchestrator uses an in-process queue.
REDIS_URL=

# Stripe — Phase 5
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Frontend (apps/web) ----------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
